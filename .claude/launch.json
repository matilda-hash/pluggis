{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend (FastAPI)",
      "runtimeExecutable": "py",
      "runtimeArgs": ["-3.12", "-m", "uvicorn", "app.main:app", "--reload", "--port", "8000"],
      "port": 8000,
      "cwd": "backend"
    },
    {
      "name": "Frontend (Vite + React)",
      "runtimeExecutable": "npm.cmd",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "cwd": "frontend"
    }
  ]
}
